# Minimal mStream container for the all-Docker smoke. Not a release
# artifact — operators run mStream natively today. The purpose here is
# to exercise the code paths a Linux-container mStream would hit when
# it talks to torrent-client containers on the same Docker network.
#
# Build context: the repo root.
# Run-time: bind-mount /config (for config.json + DB) and one or more
#   /music* dirs (library content shared with the daemons via the
#   same source volume so file-existence checks line up).

# glibc base (NOT alpine): onnxruntime-node — the discovery embedding
# runtime — ships glibc-only binaries. On musl the loader fails outright
# (`ld-linux-x86-64.so.2: No such file or directory`), and Alpine's
# gcompat shim doesn't help (onnxruntime needs fortified glibc symbols
# like __vsnprintf_chk that gcompat doesn't implement; verified 2026-07).
# bookworm-slim runs the full EffNet inference correctly.
FROM node:22-bookworm-slim

# Build tools needed by native npm bindings in some deps.
RUN apt-get update \
  && apt-get install -y --no-install-recommends build-essential python3 \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files first to leverage Docker layer cache across
# code-only changes.
COPY package.json package-lock.json* ./
RUN npm install --omit=dev

# Copy the rest of the source. The .dockerignore (next to this file)
# trims out node_modules + build artefacts so the COPY stays cheap.
COPY . .

# /config is the operator-mounted config + DB volume. mStream's
# `dbDirectory` / `albumArtDirectory` / `logsDirectory` should all
# point under /config so a container restart preserves state.
VOLUME /config

# Default HTTP port. Tests override via --port on the bind-mounted
# config.json, but this serves as a stable convention for the smoke.
EXPOSE 3000

CMD ["node", "cli-boot-wrapper.js", "-j", "/config/config.json"]
