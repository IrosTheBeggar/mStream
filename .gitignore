# Test libraries generated by scripts/gen-*-library.mjs — same rationale:
# audio + DB + caches are all reproducible from the generator scripts. Match
# anything under save/ that's prefixed `library-` or DB/cache dirs that
# accompany a generated library config.
save/library-*/
save/db-*-smoke/
save/image-cache-*-smoke/
save/waveform-cache-*-smoke/
save/logs-*-smoke/
save/image-cache-smoke/
save/waveform-cache-smoke/

